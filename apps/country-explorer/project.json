{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "country-explorer",
  "projectType": "application",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss",
      "skipTests": false,
      "standalone": true
    },
    "@schematics/angular:class": {
      "skipTests": false
    },
    "@schematics/angular:directive": {
      "skipTests": false,
      "standalone": true
    },
    "@schematics/angular:guard": {
      "skipTests": false
    },
    "@schematics/angular:interceptor": {
      "skipTests": false
    },
    "@schematics/angular:pipe": {
      "skipTests": false,
      "standalone": true
    },
    "@schematics/angular:resolver": {
      "skipTests": false
    },
    "@schematics/angular:service": {
      "skipTests": false
    }
  },
  "sourceRoot": "apps/country-explorer/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "options": {
        "outputPath": "dist/country-explorer",
        "index": "apps/country-explorer/src/index.html",
        "browser": "apps/country-explorer/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/country-explorer/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/country-explorer/public"
          }
        ],
        "styles": [
          "apps/country-explorer/src/styles.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1MB",
              "maximumError": "2MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "single-spa": {
          "browser": "apps/country-explorer/src/main.single-spa.ts",
          "tsConfig": "apps/country-explorer/tsconfig.single-spa.json",
          "outputPath": "dist/country-explorer-single-spa",
          "index": false,
          "polyfills": [],
          "outputHashing": "none",
          "optimization": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production",
      "outputs": [
        "{options.outputPath}"
      ]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "country-explorer:build:production"
        },
        "development": {
          "buildTarget": "country-explorer:build:development",
          "proxyConfig": "apps/country-explorer/proxy.conf.js"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-single-spa": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "continuous": true,
      "options": {
        "port": 4201,
        "headers": {
          "Access-Control-Allow-Origin": "*"
        },
        "buildTarget": "country-explorer:build:single-spa"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n"
    },
    "test": {
      "executor": "@angular-devkit/build-angular:jest",
      "options": {
        "tsConfig": "tsconfig.spec.json"
      }
    }
  }
}